<Window x:Class="MukundTube.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="MukundTube"
        Width="1280"
        Height="800"
        MinWidth="980"
        MinHeight="620"
        Background="White">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="White"
                BorderBrush="#E5E5E5"
                BorderThickness="0,0,0,1"
                Padding="24,0">
            <DockPanel LastChildFill="True">
                <Button DockPanel.Dock="Right"
                        MinWidth="88"
                        Height="36"
                        Padding="16,0"
                        Background="#0F0F0F"
                        Foreground="White"
                        BorderThickness="0"
                        Click="Refresh_Click"
                        Content="Refresh" />
                <StackPanel Orientation="Vertical"
                            VerticalAlignment="Center">
                    <TextBlock Text="MukundTube"
                               Foreground="#0F0F0F"
                               FontSize="20"
                               FontWeight="Bold" />
                    <TextBlock Text="{Binding StatusText}"
                               Foreground="#606060"
                               FontSize="12"
                               TextTrimming="CharacterEllipsis" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1"
              Margin="24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="24" />
                <ColumnDefinition Width="400" />
            </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="0"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <Grid Height="520"
                          Background="Black"
                          ClipToBounds="True">
                        <wv2:WebView2 x:Name="PlayerWebView" />
                    </Grid>

                    <TextBlock Text="{Binding SelectedVideoTitle}"
                               Margin="0,14,0,0"
                               Foreground="#0F0F0F"
                               FontSize="20"
                               FontWeight="Bold"
                               TextWrapping="Wrap" />
                    <TextBlock Text="{Binding SelectedVideoMeta}"
                               Margin="0,8,0,0"
                               Foreground="#606060"
                               FontSize="14"
                               TextTrimming="CharacterEllipsis" />
                </StackPanel>
            </ScrollViewer>

            <Border Grid.Column="2"
                    Background="White">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <ProgressBar Grid.Row="0"
                                 Height="3"
                                 IsIndeterminate="True"
                                 Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}" />

                    <ListBox x:Name="VideoList"
                             Grid.Row="1"
                             ItemsSource="{Binding Videos}"
                             SelectedItem="{Binding SelectedVideo, Mode=TwoWay}"
                             BorderThickness="0"
                             Background="White"
                             SelectionChanged="VideoList_SelectionChanged"
                             ScrollViewer.CanContentScroll="True"
                             VirtualizingPanel.IsVirtualizing="True"
                             VirtualizingPanel.VirtualizationMode="Recycling">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Padding" Value="0" />
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,10"
                                      Height="94">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="168" />
                                        <ColumnDefinition Width="10" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0"
                                            Width="168"
                                            Height="94"
                                            Background="#EEEEEE"
                                            CornerRadius="8"
                                            ClipToBounds="True">
                                        <Image Source="{Binding ThumbnailUrl}"
                                               Stretch="UniformToFill" />
                                    </Border>

                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="{Binding Title}"
                                                   FontWeight="Bold"
                                                   FontSize="14"
                                                   Foreground="#0F0F0F"
                                                   MaxHeight="40"
                                                   TextWrapping="Wrap"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding ChannelTitle}"
                                                   Margin="0,5,0,0"
                                                   Foreground="#606060"
                                                   FontSize="12"
                                                   TextTrimming="CharacterEllipsis" />
                                        <DockPanel Margin="0,5,0,0">
                                            <TextBlock Text="Pinned"
                                                       DockPanel.Dock="Right"
                                                       Margin="8,0,0,0"
                                                       Foreground="#065FD4"
                                                       FontSize="12"
                                                       FontWeight="Bold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsPinned}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <TextBlock Text="{Binding PublishedAtText}"
                                                       Foreground="#606060"
                                                       FontSize="12"
                                                       TextTrimming="CharacterEllipsis" />
                                        </DockPanel>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
