<Window x:Class="MukundTube.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="sneakyTube"
        Width="1280"
        Height="800"
        MinWidth="980"
        MinHeight="620"
        Background="#0F0F0F">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#0F0F0F"
                BorderBrush="#303030"
                BorderThickness="0,0,0,1"
                Padding="24,0">
            <DockPanel LastChildFill="True">
                <Button DockPanel.Dock="Right"
                        MinWidth="88"
                        Height="36"
                        Padding="16,0"
                        Background="#F1F1F1"
                        Foreground="#0F0F0F"
                        BorderThickness="0"
                        Click="Refresh_Click"
                        Content="Refresh" />
                <StackPanel Orientation="Vertical"
                            VerticalAlignment="Center">
                    <TextBlock Text="sneakyTube"
                               Foreground="#F1F1F1"
                               FontSize="20"
                               FontWeight="Bold" />
                    <TextBlock Text="{Binding StatusText}"
                               Foreground="#AAAAAA"
                               FontSize="12"
                               TextTrimming="CharacterEllipsis" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1"
              Margin="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <ProgressBar Grid.Row="0"
                         Height="3"
                         IsIndeterminate="True"
                         Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}" />

            <Grid Grid.Row="1">
                <Grid x:Name="ChannelBrowsePanel">
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsChannelSelected}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="Channels"
                               Margin="0,0,0,18"
                               Foreground="#F1F1F1"
                               FontSize="22"
                               FontWeight="Bold" />

                    <Grid Grid.Row="1">
                        <StackPanel>
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsLoading}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <Grid MinHeight="132" Margin="0,0,0,18">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="156" />
                                    <ColumnDefinition Width="18" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Width="132" Height="132" Background="#2A2A2A" CornerRadius="66" />
                                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                    <Border Height="18" Width="240" HorizontalAlignment="Left" Background="#2A2A2A" CornerRadius="9" />
                                    <Border Height="13" Width="140" HorizontalAlignment="Left" Margin="0,10,0,0" Background="#2A2A2A" CornerRadius="7" />
                                </StackPanel>
                            </Grid>
                            <Grid MinHeight="132" Margin="0,0,0,18">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="156" />
                                    <ColumnDefinition Width="18" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Width="132" Height="132" Background="#2A2A2A" CornerRadius="66" />
                                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                    <Border Height="18" Width="220" HorizontalAlignment="Left" Background="#2A2A2A" CornerRadius="9" />
                                    <Border Height="13" Width="120" HorizontalAlignment="Left" Margin="0,10,0,0" Background="#2A2A2A" CornerRadius="7" />
                                </StackPanel>
                            </Grid>
                            <Grid MinHeight="132" Margin="0,0,0,18">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="156" />
                                    <ColumnDefinition Width="18" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Width="132" Height="132" Background="#2A2A2A" CornerRadius="66" />
                                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                    <Border Height="18" Width="260" HorizontalAlignment="Left" Background="#2A2A2A" CornerRadius="9" />
                                    <Border Height="13" Width="150" HorizontalAlignment="Left" Margin="0,10,0,0" Background="#2A2A2A" CornerRadius="7" />
                                </StackPanel>
                            </Grid>
                        </StackPanel>

                        <ListBox x:Name="ChannelList"
                                 ItemsSource="{Binding Channels}"
                                 SelectedItem="{Binding SelectedChannel, Mode=TwoWay}"
                                 SelectionChanged="ChannelList_SelectionChanged"
                                 BorderThickness="0"
                                 Background="#0F0F0F"
                                 ScrollViewer.CanContentScroll="True"
                                 VirtualizingPanel.IsVirtualizing="True"
                                 VirtualizingPanel.VirtualizationMode="Recycling">
                            <ListBox.Style>
                                <Style TargetType="ListBox">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsLoading}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ListBox.Style>
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <VirtualizingStackPanel />
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="Margin" Value="0,0,0,18" />
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid MinHeight="132">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="156" />
                                            <ColumnDefinition Width="18" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <Border Width="132"
                                                Height="132"
                                                HorizontalAlignment="Center"
                                                Background="#272727"
                                                CornerRadius="66"
                                                ClipToBounds="True">
                                            <Image Source="{Binding ThumbnailUrl}"
                                                   Stretch="UniformToFill" />
                                        </Border>

                                        <StackPanel Grid.Column="2"
                                                    VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Title}"
                                                       Foreground="#F1F1F1"
                                                       FontSize="18"
                                                       FontWeight="Bold"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Text="Approved channel"
                                                       Margin="0,6,0,0"
                                                       Foreground="#AAAAAA"
                                                       FontSize="13" />
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Grid>

                <Grid x:Name="VideoBrowsePanel">
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsChannelSelected}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0"
                                Orientation="Horizontal"
                                Margin="0,0,0,18">
                        <Button MinWidth="92"
                                Height="36"
                                Padding="14,0"
                                Background="#272727"
                                Foreground="#F1F1F1"
                                BorderThickness="0"
                                Click="Back_Click"
                                Content="Channels" />
                        <TextBlock Text="{Binding SelectedChannelTitle}"
                                   Margin="14,0,0,0"
                                   VerticalAlignment="Center"
                                   Foreground="#F1F1F1"
                                   FontSize="22"
                                   FontWeight="Bold" />
                    </StackPanel>

                    <Grid Grid.Row="1"
                          Margin="0,0,0,24"
                          Background="Black"
                          ClipToBounds="True">
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="Height" Value="520" />
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedVideo}" Value="{x:Null}">
                                        <Setter Property="Height" Value="0" />
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>
                        <wv2:WebView2 x:Name="PlayerWebView" />
                    </Grid>

                    <Grid Grid.Row="2">
                        <StackPanel>
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsLoading}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <Grid Height="130" Margin="0,0,0,18">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="224" />
                                    <ColumnDefinition Width="14" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Width="224" Height="126" Background="#2A2A2A" CornerRadius="10" />
                                <StackPanel Grid.Column="2">
                                    <Border Height="17" Width="420" HorizontalAlignment="Left" Background="#2A2A2A" CornerRadius="9" />
                                    <Border Height="13" Width="180" HorizontalAlignment="Left" Margin="0,10,0,0" Background="#2A2A2A" CornerRadius="7" />
                                </StackPanel>
                            </Grid>
                            <Grid Height="130" Margin="0,0,0,18">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="224" />
                                    <ColumnDefinition Width="14" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Width="224" Height="126" Background="#2A2A2A" CornerRadius="10" />
                                <StackPanel Grid.Column="2">
                                    <Border Height="17" Width="360" HorizontalAlignment="Left" Background="#2A2A2A" CornerRadius="9" />
                                    <Border Height="13" Width="160" HorizontalAlignment="Left" Margin="0,10,0,0" Background="#2A2A2A" CornerRadius="7" />
                                </StackPanel>
                            </Grid>
                            <Grid Height="130" Margin="0,0,0,18">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="224" />
                                    <ColumnDefinition Width="14" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Width="224" Height="126" Background="#2A2A2A" CornerRadius="10" />
                                <StackPanel Grid.Column="2">
                                    <Border Height="17" Width="390" HorizontalAlignment="Left" Background="#2A2A2A" CornerRadius="9" />
                                    <Border Height="13" Width="150" HorizontalAlignment="Left" Margin="0,10,0,0" Background="#2A2A2A" CornerRadius="7" />
                                </StackPanel>
                            </Grid>
                        </StackPanel>

                        <ListBox x:Name="VideoList"
                                 ItemsSource="{Binding Videos}"
                                 SelectedItem="{Binding SelectedVideo, Mode=TwoWay}"
                                 BorderThickness="0"
                                 Background="#0F0F0F"
                                 SelectionChanged="VideoList_SelectionChanged"
                                 ScrollViewer.CanContentScroll="True"
                                 VirtualizingPanel.IsVirtualizing="True"
                                 VirtualizingPanel.VirtualizationMode="Recycling">
                            <ListBox.Style>
                                <Style TargetType="ListBox">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsLoading}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ListBox.Style>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="Margin" Value="0,0,0,18" />
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Height="130">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="224" />
                                            <ColumnDefinition Width="14" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <Border Width="224"
                                            Height="126"
                                            Background="#272727"
                                                CornerRadius="10"
                                                ClipToBounds="True">
                                            <Image Source="{Binding ThumbnailUrl}"
                                                   Stretch="UniformToFill" />
                                        </Border>

                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="{Binding Title}"
                                                       FontWeight="Bold"
                                                       FontSize="15"
                                                       Foreground="#F1F1F1"
                                                       MaxHeight="44"
                                                       TextWrapping="Wrap"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{Binding PublishedAtText}"
                                                       Margin="0,6,0,0"
                                                       Foreground="#AAAAAA"
                                                       FontSize="13"
                                                       TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Grid>
            </Grid>
        </Grid>

        <Grid Grid.RowSpan="2"
              Background="#E6000000"
              Visibility="{Binding IsUpdateRequired, Converter={StaticResource BoolToVisibilityConverter}}">
            <Border Width="520"
                    Padding="28"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="#181818"
                    BorderBrush="#303030"
                    BorderThickness="1"
                    CornerRadius="8">
                <StackPanel>
                    <TextBlock Text="Update required"
                               Foreground="#F1F1F1"
                               FontSize="24"
                               FontWeight="Bold" />
                    <TextBlock Text="{Binding UpdateMessage}"
                               Margin="0,12,0,0"
                               Foreground="#F1F1F1"
                               FontSize="15"
                               TextWrapping="Wrap" />
                    <TextBlock Text="{Binding UpdateNotes}"
                               Margin="0,10,0,0"
                               Foreground="#AAAAAA"
                               FontSize="13"
                               TextWrapping="Wrap" />
                    <Button Height="40"
                            Margin="0,22,0,0"
                            Padding="18,0"
                            HorizontalAlignment="Left"
                            Background="#F1F1F1"
                            Foreground="#0F0F0F"
                            BorderThickness="0"
                            Click="InstallUpdate_Click"
                            Content="Download and install" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
