<Window x:Class="MukundTube.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Youtube Beta"
        Icon="Assets/Icons/youtube-beta.ico"
        Width="1280"
        Height="800"
        MinWidth="980"
        MinHeight="620"
        WindowState="Maximized"
        Background="#0F0F0F">
    <Window.Resources>
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="MinWidth" Value="88" />
            <Setter Property="Height" Value="36" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="Background" Value="#F1F1F1" />
            <Setter Property="Foreground" Value="#0F0F0F" />
            <Setter Property="BorderBrush" Value="#F1F1F1" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FFFFFF" />
                                <Setter Property="BorderBrush" Value="#FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#D8D8D8" />
                                <Setter Property="BorderBrush" Value="#D8D8D8" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="QuietButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="36" />
            <Setter Property="Padding" Value="14,0" />
            <Setter Property="Background" Value="#272727" />
            <Setter Property="Foreground" Value="#F1F1F1" />
            <Setter Property="BorderBrush" Value="#3F3F3F" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#F1F1F1" />
                                <Setter Property="Foreground" Value="#0F0F0F" />
                                <Setter Property="BorderBrush" Value="#F1F1F1" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#D8D8D8" />
                                <Setter Property="Foreground" Value="#0F0F0F" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PlainListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemBorder"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                Padding="6">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#202020" />
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#3F3F3F" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#303030" />
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#F1F1F1" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="VideoCardTemplate">
            <StackPanel>
                <Border Width="260"
                        Height="146"
                        Background="#272727"
                        CornerRadius="8"
                        ClipToBounds="True">
                    <Image Source="{Binding ThumbnailUrl}"
                           Stretch="UniformToFill" />
                </Border>
                <TextBlock Text="{Binding Title}"
                           Margin="0,10,0,0"
                           FontWeight="Bold"
                           FontSize="15"
                           Foreground="#F1F1F1"
                           MaxHeight="44"
                           TextWrapping="Wrap"
                           TextTrimming="CharacterEllipsis" />
                <TextBlock Text="{Binding ChannelTitle}"
                           Margin="0,6,0,0"
                           Foreground="#AAAAAA"
                           FontSize="13"
                           TextTrimming="CharacterEllipsis" />
            </StackPanel>
        </DataTemplate>

        <DataTemplate x:Key="ShortCardTemplate">
            <StackPanel Width="150">
                <Border Width="150"
                        Height="220"
                        Background="#272727"
                        CornerRadius="8"
                        ClipToBounds="True">
                    <Image Source="{Binding ThumbnailUrl}"
                           Stretch="UniformToFill" />
                </Border>
                <TextBlock Text="{Binding Title}"
                           Margin="0,10,0,0"
                           FontWeight="Bold"
                           FontSize="14"
                           Foreground="#F1F1F1"
                           MaxHeight="54"
                           TextWrapping="Wrap"
                           TextTrimming="CharacterEllipsis" />
            </StackPanel>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#0F0F0F"
                BorderBrush="#303030"
                BorderThickness="0,0,0,1"
                Padding="24,0">
            <DockPanel LastChildFill="True">
                <Button DockPanel.Dock="Right"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Click="Refresh_Click"
                        Content="Refresh" />
                <StackPanel Orientation="Vertical"
                            VerticalAlignment="Center">
                    <TextBlock Text="Youtube Beta"
                               Foreground="#F1F1F1"
                               FontSize="20"
                               FontWeight="Bold" />
                    <TextBlock Text="{Binding StatusText}"
                               Foreground="#AAAAAA"
                               FontSize="12"
                               TextTrimming="CharacterEllipsis" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="#151515"
                    BorderBrush="#303030"
                    BorderThickness="0,0,1,0"
                    Padding="18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0"
                               Text="Channels"
                               Foreground="#F1F1F1"
                               FontSize="18"
                               FontWeight="Bold" />
                    <Button Grid.Row="1"
                            Margin="0,16,0,14"
                            HorizontalAlignment="Stretch"
                            Style="{StaticResource QuietButtonStyle}"
                            Click="Refresh_Click"
                            Content="All channels" />
                    <ListBox Grid.Row="2"
                             x:Name="ChannelList"
                             ItemsSource="{Binding Channels}"
                             SelectedItem="{Binding SelectedChannel, Mode=TwoWay}"
                             SelectionChanged="ChannelList_SelectionChanged"
                             BorderThickness="0"
                             Background="#151515"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Auto"
                             ItemContainerStyle="{StaticResource PlainListBoxItemStyle}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="48" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Width="38"
                                            Height="38"
                                            Background="#272727"
                                            CornerRadius="19"
                                            ClipToBounds="True">
                                        <Image Source="{Binding ThumbnailUrl}"
                                               Stretch="UniformToFill" />
                                    </Border>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Title}"
                                               VerticalAlignment="Center"
                                               Foreground="#F1F1F1"
                                               FontSize="14"
                                               FontWeight="Bold"
                                               TextTrimming="CharacterEllipsis" />
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>

            <Grid Grid.Column="1"
                  Margin="24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <ProgressBar Grid.Row="0"
                             Height="3"
                             IsIndeterminate="True"
                             Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}" />

                <Grid Grid.Row="1"
                      Margin="0,0,0,22"
                      Background="Black"
                      ClipToBounds="True">
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Height" Value="520" />
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding SelectedVideo}" Value="{x:Null}">
                                    <Setter Property="Height" Value="0" />
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <wv2:WebView2 x:Name="PlayerWebView" />
                </Grid>

                <ScrollViewer Grid.Row="2"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,16">
                            <TextBlock Text="{Binding SelectedChannelTitle}"
                                       Foreground="#F1F1F1"
                                       FontSize="24"
                                       FontWeight="Bold" />
                        </DockPanel>

                        <TextBlock Text="Shorts"
                                   Foreground="#F1F1F1"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Visibility="{Binding HasShorts, Converter={StaticResource BoolToVisibilityConverter}}" />
                        <ListBox x:Name="ShortsList"
                                 Height="318"
                                 Margin="0,14,0,28"
                                 ItemsSource="{Binding Shorts}"
                                 BorderThickness="0"
                                 Background="#0F0F0F"
                                 SelectionChanged="VideoList_SelectionChanged"
                                 ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                 ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                 ScrollViewer.CanContentScroll="True"
                                 VirtualizingPanel.IsVirtualizing="True"
                                 VirtualizingPanel.VirtualizationMode="Recycling"
                                 Visibility="{Binding HasShorts, Converter={StaticResource BoolToVisibilityConverter}}">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <VirtualizingStackPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemContainerStyle>
                                <Style BasedOn="{StaticResource PlainListBoxItemStyle}" TargetType="ListBoxItem">
                                    <Setter Property="Width" Value="172" />
                                    <Setter Property="Margin" Value="0,0,14,0" />
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <StaticResource ResourceKey="ShortCardTemplate" />
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <TextBlock Text="Recent videos"
                                   Foreground="#F1F1F1"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Visibility="{Binding HasLongVideos, Converter={StaticResource BoolToVisibilityConverter}}" />
                        <ListBox x:Name="VideoList"
                                 Margin="0,14,0,0"
                                 ItemsSource="{Binding Videos}"
                                 BorderThickness="0"
                                 Background="#0F0F0F"
                                 SelectionChanged="VideoList_SelectionChanged"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.VerticalScrollBarVisibility="Disabled"
                                 ScrollViewer.CanContentScroll="False"
                                 Visibility="{Binding HasLongVideos, Converter={StaticResource BoolToVisibilityConverter}}">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemContainerStyle>
                                <Style BasedOn="{StaticResource PlainListBoxItemStyle}" TargetType="ListBoxItem">
                                    <Setter Property="Width" Value="282" />
                                    <Setter Property="Margin" Value="0,0,18,28" />
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <StaticResource ResourceKey="VideoCardTemplate" />
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>

        <Grid Grid.RowSpan="2"
              Background="#E6000000"
              Visibility="{Binding IsUpdateRequired, Converter={StaticResource BoolToVisibilityConverter}}">
            <Border Width="520"
                    Padding="28"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Background="#181818"
                    BorderBrush="#303030"
                    BorderThickness="1"
                    CornerRadius="8">
                <StackPanel>
                    <TextBlock Text="Update required"
                               Foreground="#F1F1F1"
                               FontSize="24"
                               FontWeight="Bold" />
                    <TextBlock Text="{Binding UpdateMessage}"
                               Margin="0,12,0,0"
                               Foreground="#F1F1F1"
                               FontSize="15"
                               TextWrapping="Wrap" />
                    <TextBlock Text="{Binding UpdateNotes}"
                               Margin="0,10,0,0"
                               Foreground="#AAAAAA"
                               FontSize="13"
                               TextWrapping="Wrap" />
                    <Button Height="40"
                            Margin="0,22,0,0"
                            Padding="18,0"
                            HorizontalAlignment="Left"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Click="InstallUpdate_Click"
                            Content="Download and install" />
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
